#!/bin/sh
#|-*- mode:lisp -*-|#
#|
exec ros -Q -- $0 "$@"
|#
(progn ;;init forms
  (ros:ensure-asdf)
  #+quicklisp (ql:quickload '(lisp-chat/client lisp-chat/tui) :silent t))

(defpackage :ros.script.lisp-chat
  (:use :cl)
  (:local-nicknames (#:config #:lisp-chat/config)
                    (#:client #:lisp-chat/client)
                    (#:net #:lisp-chat/client/net)
                    (#:tui #:lisp-chat/tui)))

(in-package :ros.script.lisp-chat)

(eval-when (:compile-toplevel :load-toplevel :execute)
  (when (equal (uiop:getenv "APP_ENV") "PROD")
    (setq lisp-chat/config:*host* "wss://chat.manoel.dev/ws")))

(defparameter *usage*
  (format nil
          "usage: lisp-chat [-h|--help] [host] [port]

OPTIONS
    host            server host, default: ~a
    port            server port, default: ~a
    -r | --readline use the readline version
    -h | --help     show this message
    -v | --version  show version of the software
"
          config:*host*
          config:*port*))

(defun setup-host-port (host port)
  (when host
    (setq lisp-chat/config:*host* host)
    ;; If host is WS, we might want to default to websocket-port if port not provided
    (when (and (net:websocket-p host port)
               (null port))
      (setq config:*port* config:*websocket-port*)))
  (when port
    (setq config:*port* (parse-integer port))))

(defun clean-args (args)
  "Remove dashed args like -flag and --flags"
  (loop for arg in args
        when (not (equal (aref arg 0) #\-))
          collect arg))

(defun main (&rest argv)
  (let* ((args (clean-args argv))
         (host (car args))
         (port (cadr args)))
    (setup-host-port host port))

  (cond
    ((config:has-any-flags argv "-h" "--help") (princ *usage*))
    ((config:has-any-flags argv "-v" "--version") (princ (config:get-version)))
    ((config:has-any-flags argv "-r" "--readline")
     (client:main :host config:*host*
                  :port config:*port*))
    (t (tui:main :host config:*host*
                 :port config:*port*))))
;;; vim: set ft=lisp lisp:
